codex-rs/app-server-protocol/schema/** linguist-generated
codex-rs/hooks/schema/generated/** linguist-generated

# sqlx embeds migration file bytes into built binaries and validates those
# bytes against local DB checksums. Keep migration SQL line endings stable
# across Windows/macOS/Linux checkouts.
codex-rs/state/migrations/*.sql text eol=lf
codex-rs/state/logs_migrations/*.sql text eol=lf
codex-rs/state/goals_migrations/*.sql text eol=lf
codex-rs/state/memory_migrations/*.sql text eol=lf
